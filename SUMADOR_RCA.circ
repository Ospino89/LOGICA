# Sumador Ripple Carry (RCA) de 4 bits - LogicSim
# Componentes: Full Adders en cascada

# FULL ADDER 0 (bits menos significativos)
# Entrada: A0, B0, Cin
# Salida: Sum0, Cout0

w 0 0 0 64
# XOR para Sum0
w 0 16 0 32
x 16 0 48 16
x 16 32 48 48
w 48 8 80 8
# AND para Cout0 (parte 1)
x 16 64 48 80
x 16 80 48 96
a 48 80 80 96
# AND para Cout0 (parte 2)
x 0 0 16 16
a 16 16 48 32
# OR para Cout0
o 80 96 96 104
w 96 100 96 128

# FULL ADDER 1
# Entrada: A1, B1, Cout0
# Salida: Sum1, Cout1

w 128 0 128 64
x 128 0 160 16
x 128 32 160 48
w 160 8 192 8
x 128 64 160 80
x 128 80 160 96
a 160 80 192 96
x 96 100 128 16
a 128 16 160 32
o 192 96 208 104
w 208 100 208 128

# FULL ADDER 2
# Entrada: A2, B2, Cout1
# Salida: Sum2, Cout2

w 256 0 256 64
x 256 0 288 16
x 256 32 288 48
w 288 8 320 8
x 256 64 288 80
x 256 80 288 96
a 288 80 320 96
x 208 100 256 16
a 256 16 288 32
o 320 96 336 104
w 336 100 336 128

# FULL ADDER 3
# Entrada: A3, B3, Cout2
# Salida: Sum3, Cout (Overflow)

w 384 0 384 64
x 384 0 416 16
x 384 32 416 48
w 416 8 448 8
x 384 64 416 80
x 384 80 416 96
a 416 80 448 96
x 336 100 384 16
a 384 16 416 32
o 448 96 464 104
w 464 100 464 128

# Entradas
i 0 0 8 Ain[0]
i 0 32 8 Bin[0]
i 0 64 8 Cin

i 128 0 8 Ain[1]
i 128 32 8 Bin[1]

i 256 0 8 Ain[2]
i 256 32 8 Bin[2]

i 384 0 8 Ain[3]
i 384 32 8 Bin[3]

# Salidas
o 80 8 88 Sum[0]
o 208 8 216 Sum[1]
o 336 8 344 Sum[2]
o 464 8 472 Sum[3]

o 96 128 104 Cout
